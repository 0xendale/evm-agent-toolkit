{
  "name": "@0xendale/evm-agent-toolkit",
  "version": "1.1.0",
  "description": "MCP server for EVM security analysis, gas profiling, compiler diagnostics, transaction simulation, call tracing, and Foundry test orchestration — deterministic, schema-validated tools for autonomous coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xendale/evm-agent-toolkit.git"
  },
  "homepage": "https://github.com/0xendale/evm-agent-toolkit#readme",
  "bugs": {
    "url": "https://github.com/0xendale/evm-agent-toolkit/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "evm",
    "ethereum",
    "solidity",
    "slither",
    "foundry",
    "forge",
    "security",
    "gas-optimization",
    "smart-contracts",
    "autonomous-agents"
  ],
  "main": "build/mcp/index.js",
  "type": "module",
  "files": [
    "build",
    "skills"
  ],
  "bin": {
    "evm-agent-toolkit": "./build/mcp/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx watch src/mcp/index.ts",
    "clean": "rm -rf build",
    "test": "vitest run",
    "bench": "npx tsx bench/parser.bench.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
